  "architecturalDecisions": [
    {
      "decision": "Worktree ownership",
      "choice": "CLI owns all worktree ops; skills are completely blind"
    },
    {
      "decision": "Slug derivation",
      "choice": "CLI's slugify() is sole authority; skills receive slugs as arguments"
    },
    {
      "decision": "Entry point",
      "choice": "beastmode <phase> <slug> replaces Justfile recipes"
    },
    {
      "decision": "Implement fan-out",
      "choice": "Single epic worktree shared by parallel SDK sessions; no per-feature worktrees"
    },
    {
      "decision": "Release boundary",
      "choice": "Release skill keeps squash-merge to main (git ops); CLI does post-release cleanup"
    },
    {
      "decision": "Error recovery",
      "choice": "Failed phases leave worktree dirty for retry; ensureWorktree() reuses on next run"
    }
