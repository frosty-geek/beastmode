{
  "name": "beastmode",
  "version": "0.45.0",
  "type": "module",
  "bin": {
    "beastmode": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun --bun vitest run",
    "test:watch": "bun --bun vitest",
    "cucumber": "bun --bun node_modules/.bin/cucumber-js",
    "test:integration": "bun --bun node_modules/.bin/cucumber-js",
    "typecheck": "bun x tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "chalk": "^5.4.1",
    "ink": "^6.8.0",
    "react": "^19.0.0",
    "xstate": "^5.30.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
